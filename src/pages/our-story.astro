---
import Layout from '../layouts/Layout.astro';
import { config } from '../config';

const places = [
  { name: "Electric Forest", logo: "/brand/fest-electric-forest.png" },
  { name: "Summer Camp", logo: "/brand/fest-summer-camp.png" },
  { name: "Vans Warped Tour", logo: "/brand/fest-vans-warped.png" },
  { name: "Waterfront Blues Festival", logo: "/brand/fest-waterfront-blues.png" },
  { name: "Hulaween", logo: "/brand/fest-hulaween.png" },
  { name: "Farm Aid", logo: "/brand/fest-farm-aid.png" },
  { name: "Bohemian Nights", logo: "/brand/fest-bohemian.png" },
  { name: "Okeechobee", logo: "/brand/fest-okeechobee.png" },
  { name: "Montana Folk Festival", logo: "/brand/fest-montana.png" },
  { name: "Faster Horses Festival", logo: "/brand/fest-faster-horses.png" },
  { name: "Lollapalooza", logo: "/brand/fest-lollapalooza.png" },
  { name: "North Coast Music Festival", logo: "/brand/fest-north-coast.png" },
  { name: "Austin City Limits", logo: "/brand/fest-austin-city-limits.png" },
  { name: "Outside Lands", logo: "/brand/fest-outside-lands.png" },
  { name: "Paradigm Talent Agency", logo: "/brand/fest-paradigm.png" },
];

const photos = [
  "/brand/story-photo-1.jpg",
  "/brand/story-photo-2.jpg",
  "/brand/story-photo-3.jpg",
  "/brand/story-photo-4.jpg",
  "/brand/story-photo-5.jpg",
  "/brand/story-photo-6.jpg",
];
---

<Layout title="Our Story" description="How Project Decibel started — and where it's been.">
  <!-- ── Intro ──────────────────────────────────────────────────── -->
  <section class="section">
    <div class="container intro-grid">
      <div class="intro-copy">
        <p class="page-eyebrow">Our Story</p>
        <h1>Where We Started</h1>
        <div class="story-content mt-md">
          <p>
            Project Decibel grew out of a simple frustration: the people who needed hearing
            protection the most — musicians, crew members, festival workers — struggled to access
            it. Custom earplugs often meant finding an audiology clinic, a wait, an upsell and a
            big bill. Most people skipped it.
          </p>
          <p class="mt-sm">
            So we brought the clinic to the festival. Since day one, the mission has been to make
            hearing wellness more accessible and affordable for music industry personnel: on-site
            ear impressions, earwax removal, screenings, and consultations for musicians, crews, and staff.
          </p>
          <p class="mt-sm">
            Today the practice is based in Denver, CO, with a focus on individual patients and
            private events. The mission hasn't changed.
          </p>
        </div>
      </div>
      <div class="intro-art">
        <img src="/brand/ears-holding-hands.png" alt="" aria-hidden="true" />
      </div>
    </div>
  </section>

  <!-- ── Meet the Audiologist ───────────────────────────────────── -->
  <section class="section section--alt">
    <div class="container founder">
      <div class="founder-photo">
        <img src="/brand/jenna-paley.jpg" alt="Dr. Jenna, founder of Project Decibel" />
      </div>
      <div class="founder-text">
        <p class="page-eyebrow">Meet the Audiologist</p>
        <h2>Hi, I'm Dr. Jenna.</h2>
        <p class="mt-sm">
          I'm the Audiologist behind Project Decibel. I started this practice on a simple belief:
          protecting your hearing shouldn't mean an expensive, inconvenient trip to a clinic. So I
          bring the clinic to you. From living rooms to music festivals, I've been fitting custom
          ear protection for musicians, crews, and everyday people who want to keep doing what they
          love without risking their hearing.
        </p>
        <p class="mt-sm">
          My focus has always been prevention: catching issues early, making custom-fit protection
          accessible, and helping people understand how their hearing actually works. These days I'm
          keeping things intentionally small and personal, so every client gets my full attention.
        </p>
      </div>
    </div>
  </section>

  <!-- ── Our Partners and Impact ────────────────────────────────── -->
  <section class="section">
    <div class="container">
      <p class="page-eyebrow">Our Partners and Impact</p>
      <h2>Where We've Been</h2>
      <p class="mt-sm section-sub">
        A look at the festivals, events, and partners Project Decibel has served on-site over the years.
      </p>

      <div class="impact-grid mt-lg">
        {places.map(p => (
          <div class:list={["impact-tile", p.dark && "impact-tile--dark"]}>
            <img src={p.logo} alt={p.name} />
          </div>
        ))}
      </div>

      <div class="impact-photos mt-lg">
        {photos.map(src => (
          <div class="impact-photo"><img src={src} alt="" aria-hidden="true" /></div>
        ))}
      </div>
    </div>
  </section>

  <!-- ── What Makes Us Different ────────────────────────────────── -->
  <section class="section section--alt">
    <div class="container">
      <h2 class="text-center">What Makes Us Different</h2>
      <div class="diff-grid mt-lg">
        <div class="diff-card">
          <div class="diff-icon" aria-hidden="true">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"><path d="M14 3H7a2 2 0 0 0-2 2v14a2 2 0 0 0 2 2h10a2 2 0 0 0 2-2V8z"/><path d="M14 3v5h5"/><path d="M12 11.5v5"/><path d="M9.5 14l2.5 2.5L14.5 14"/></svg>
          </div>
          <h3>You own your impressions</h3>
          <p>
            We scan your ear impressions into a 3D digital file you can request and take
            with you — order from us or any manufacturer you choose. No vendor lock-in.
          </p>
        </div>
        <div class="diff-card">
          <div class="diff-icon" aria-hidden="true">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"><path d="M9 18V6l11-2.2V15"/><circle cx="6.2" cy="18" r="2.8"/><circle cx="17.2" cy="15.5" r="2.8"/></svg>
          </div>
          <h3>Built for the music industry</h3>
          <p>
            We specialize in musicians, crews, and festival professionals — the people
            whose careers and joy depend on protecting their hearing.
          </p>
        </div>
        <div class="diff-card">
          <div class="diff-icon" aria-hidden="true">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"><path d="M20.8 6a5 5 0 0 0-7.1 0L12 7.6 10.3 6A5 5 0 1 0 3.2 13L12 21.4 20.8 13a5 5 0 0 0 0-7z"/></svg>
          </div>
          <h3>Never any pressure</h3>
          <p>
            We will never push you toward anything. We're committed to finding the right
            solution that fits each person's unique needs and life.
          </p>
        </div>
      </div>
    </div>
  </section>

  <!-- ── Work together CTA ──────────────────────────────────────── -->
  <section class="section">
    <div class="container cta-block text-center">
      <h2>Bring PdB to Your Event</h2>
      <p class="mt-sm">
        Interested in on-site audiology for your festival, venue, label, or team?
        Group pricing applies for bookings of 5 or more, and one concierge fee covers the whole group.
      </p>
      <a href={`mailto:${config.email}?subject=Event Partnership`} class="btn btn--primary mt-md">
        Get in touch
      </a>
    </div>
  </section>
</Layout>

<style>
  /* ── Intro ── */
  .intro-grid { display: grid; grid-template-columns: 1.4fr 0.8fr; gap: 48px; align-items: center; }
  .story-content p { font-size: 1.05rem; color: #333; }
  .intro-art img { width: 100%; max-width: 360px; margin-left: auto; }

  .section-sub { font-size: 1rem; color: #555; max-width: 64ch; }

  /* ── Meet the Audiologist ── */
  .founder { display: grid; grid-template-columns: 280px 1fr; gap: 48px; align-items: center; }
  .founder-photo img { width: 100%; max-width: 280px; border-radius: 12px; display: block; }

  /* ── Impact: logo wall ── */
  .impact-grid { display: grid; grid-template-columns: repeat(auto-fill, minmax(170px, 1fr)); gap: 14px; }
  .impact-tile {
    background: #fff; border: 1.5px solid var(--ink); border-radius: 8px; height: 96px;
    display: flex; align-items: center; justify-content: center; padding: 16px;
  }
  .impact-tile img { max-height: 56px; max-width: 84%; object-fit: contain; }
  .impact-tile--dark { background: var(--teal); }

  /* ── Impact: photos ── */
  .impact-photos { display: grid; grid-template-columns: repeat(3, 1fr); gap: 18px; }
  .impact-photo {
    aspect-ratio: 1 / 1; border: 1.5px solid var(--ink); border-radius: 12px;
    box-shadow: 5px 5px 0 var(--teal); overflow: hidden;
  }
  .impact-photo img { width: 100%; height: 100%; object-fit: cover; display: block; }

  /* ── What Makes Us Different ── */
  .diff-grid { display: grid; grid-template-columns: repeat(3, 1fr); gap: 24px; }
  .diff-card { background: white; border: 1.5px solid var(--ink); border-radius: 10px; padding: 28px 24px; box-shadow: 4px 4px 0 var(--teal); }
  .diff-icon { width: 38px; height: 38px; color: var(--rust); margin-bottom: 14px; }
  .diff-icon svg { width: 100%; height: 100%; }
  .diff-card h3 { margin-bottom: 8px; font-size: 1.05rem; }
  .diff-card p { font-size: 0.9rem; color: #555; }

  /* ── CTA (centered) ── */
  .cta-block { max-width: 560px; margin: 0 auto; }
  .cta-block p { color: #444; }

  @media (max-width: 900px) {
    .diff-grid { grid-template-columns: 1fr; }
    .impact-photos { grid-template-columns: repeat(2, 1fr); }
  }

  @media (max-width: 768px) {
    .intro-grid { grid-template-columns: 1fr; }
    .intro-art { display: none; }
    .founder { grid-template-columns: 1fr; text-align: center; }
    .founder-photo img { margin: 0 auto; }
  }

  @media (max-width: 480px) {
    .impact-photos { grid-template-columns: 1fr; }
  }
</style>
