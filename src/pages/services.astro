---
import Layout from '../layouts/Layout.astro';
import { config } from '../config';

const groupPrice = (price: number) => Math.round(price * (1 - config.groupDiscount));

const products = [
  {
    name: "Custom Filtered Earplugs",
    img: "/brand/product-filtered-earplugs.png",
    copy: "Forget the foam. Custom-fit earplugs with an acoustic filter that lowers the volume evenly, so live music stays clear at a safer level. Includes your color choice and one set of filters.",
  },
  {
    name: "Custom Sleep Plugs",
    img: "/brand/product-sleep-plugs.png",
    copy: "Completely solid, super-soft silicone plugs custom-fit to your ears — more than 26 dB of isolation for tour buses, snorers, busy streets, or just some peace and quiet.",
  },
  {
    name: "Custom IEMs",
    img: "/brand/product-iems-transparent.png",
    copy: "Studio- and stage-ready in-ear monitors, custom-molded from your impressions through our manufacturer partners. Manufacturer retail, varies by model.",
    big: true,
  },
  {
    name: "Custom Earbud Tips",
    img: "/brand/product-earbud-tips.png",
    copy: "Turn your universal-fit earbuds into a sealed, fully custom fit. We work with multiple manufacturers — reach out with your make and model.",
    note: "Contact for pricing — depends on your earphone model.",
  },
];
---

<Layout title="Services & Products" description="Audiology services, custom ear gear, and pricing for Project Decibel, Denver CO.">
  <!-- ── Hero ───────────────────────────────────────────────────── -->
  <section class="section">
    <div class="container hero-grid">
      <div class="hero-copy">
        <p class="page-eyebrow">Services &amp; Products</p>
        <h1>What We Offer</h1>
        <p class="hero-sub mt-sm">
          We're a mobile-first practice! We come to you for impressions, consultations,
          screenings, and wax removal, then build custom ear gear from your digital impressions.
          Based in Denver, CO and available to travel.
        </p>
        <p class="schedule-note">
          <strong>Currently scheduling</strong> concierge appointments (we come to you) on
          Wednesday and Friday afternoons in the Denver area.
        </p>
      </div>
      <div class="hero-art">
        <img src="/brand/ear-bus.png" alt="" aria-hidden="true" />
      </div>
    </div>
  </section>

  <!-- ── The PdB Package ────────────────────────────────────────── -->
  <section class="section">
    <div class="container package">
      <div class="package-text">
        <p class="eyebrow-sand">Flagship</p>
        <h2>The PdB Package</h2>
        <p class="package-desc">
          The best way to start. One visit covers a full hearing consultation, digital ear
          impressions for both ears (available for download), and a pair of custom filtered
          earplugs in your choice of color and style.
        </p>
        <div class="package-price-row">
          <span class="package-price">${config.pricing.pdbPackage}</span>
          <span class="package-group">${groupPrice(config.pricing.pdbPackage)}/person for groups of 5+</span>
        </div>
        <div class="flex flex-wrap gap-sm mt-md">
          <a href={config.bookingConcierge} class="btn btn--light" target="_blank" rel="noopener">Book a Concierge Visit</a>
          <a href={config.bookingClinic} class="btn btn--onteal-ghost" target="_blank" rel="noopener">Book a Friday Clinic</a>
        </div>
      </div>
      <div class="package-includes">
        <div class="includes-label">What's included</div>
        <ul>
          <li>Full hearing consultation with Dr. Jenna</li>
          <li>Digital ear impressions — both ears, on file for future orders</li>
          <li>One pair of custom filtered earplugs</li>
          <li>Your choice of color and style</li>
        </ul>
      </div>
    </div>
  </section>

  <!-- ── À la Carte + Group Pricing ─────────────────────────────── -->
  <section class="section section--alt">
    <div class="container">
      <h2>À la Carte</h2>
      <p class="mt-sm section-note">
        For patients who only need a specific service. All prices reflect individual appointments.
      </p>

      <div class="service-list mt-lg">
        <div class="service-row">
          <div class="service-info">
            <h3>Ear Impressions</h3>
            <p>Digital impressions for both ears, plus a brief consultation. Stored on file — use them for any future order.</p>
          </div>
          <div class="service-pricing">
            <div class="price">${config.pricing.earImpressions}</div>
            <div class="price-group-note">${groupPrice(config.pricing.earImpressions)}/person · groups of 5+</div>
          </div>
        </div>

        <div class="service-row">
          <div class="service-info">
            <h3>Custom Filtered Earplugs</h3>
            <p>Musician-grade filtered earplugs that lower the volume without sacrificing sound quality. Requires ear impressions on file.</p>
          </div>
          <div class="service-pricing">
            <div class="price">${config.pricing.filteredEarplugs}</div>
          </div>
        </div>

        <div class="service-row">
          <div class="service-info">
            <h3>Custom Sleep Plugs</h3>
            <p>Made-to-fit plugs for blocking out noise at night — comfortable enough to sleep on.</p>
          </div>
          <div class="service-pricing">
            <div class="price">${config.pricing.sleepPlugs}</div>
          </div>
        </div>

        <div class="service-row">
          <div class="service-info">
            <h3>Wax Removal</h3>
            <p>Safe, professional earwax removal. Priced per ear.</p>
          </div>
          <div class="service-pricing">
            <div class="price">${config.pricing.waxRemovalPerEar}/ear</div>
          </div>
        </div>

        <div class="service-row">
          <div class="service-info">
            <h3>Custom In-Ear Monitors (IEMs)</h3>
            <p>Custom-molded IEMs through our manufacturer partners — Sensaphonics, Ultimate Ears Pro, and JH Audio.</p>
          </div>
          <div class="service-pricing">
            <div class="price">Manufacturer retail</div>
            <div class="price-group-note">Varies by model</div>
          </div>
        </div>

        <div class="service-row">
          <div class="service-info">
            <h3>Concierge Visit</h3>
            <p>We come to you — your home, venue, hotel, or office. One fee covers the whole group for group bookings.</p>
          </div>
          <div class="service-pricing">
            <div class="price">${config.pricing.conciergeWithinDenver}</div>
            <div class="price-group-note">Within Denver · Call for a quote beyond city limits</div>
          </div>
        </div>
      </div>

      <!-- Group pricing (compact, inside pricing) -->
      <div class="group-block">
        <div class="group-copy">
          <h3>Group Pricing</h3>
          <p class="group-intro mt-xs">
            Booking a band, crew, or corporate wellness event? Groups of 5+ get 20% off the
            package and impressions, and one concierge fee covers the whole group.
            <a href={`mailto:${config.email}?subject=Group Booking`}>Get in touch →</a>
          </p>
        </div>
        <table class="group-table">
          <thead>
            <tr><th>Service</th><th>Individual</th><th>Group (5+)</th></tr>
          </thead>
          <tbody>
            <tr>
              <td>The PdB Package</td>
              <td>${config.pricing.pdbPackage}</td>
              <td>${groupPrice(config.pricing.pdbPackage)}/person</td>
            </tr>
            <tr>
              <td>Ear Impressions</td>
              <td>${config.pricing.earImpressions}</td>
              <td>${groupPrice(config.pricing.earImpressions)}/person</td>
            </tr>
          </tbody>
        </table>
      </div>
    </div>
  </section>

  <!-- ── Custom Products ────────────────────────────────────────── -->
  <section class="section">
    <div class="container">
      <p class="page-eyebrow">Custom Products</p>
      <h2>One Size Fits You</h2>
      <p class="mt-sm products-intro">
        Custom products are one size fits <em>you</em> — we take an impression of your ears and
        custom craft earplugs, sleep plugs, sleeves, and in-ear monitors for a perfect fit.
      </p>

      <div class="product-grid mt-lg">
        {products.map(p => (
          <div class="product-card">
            <div class="product-photo"><img src={p.img} alt={p.name} class={p.big ? "lg" : undefined} /></div>
            <div class="product-body">
              <h3>{p.name}</h3>
              <p>{p.copy}</p>
              {p.note && <p class="product-note">{p.note}</p>}
            </div>
          </div>
        ))}
      </div>

      <div class="color-sheets mt-lg">
        <span class="color-label">Browse custom colors:</span>
        <a href="https://www.sensaphonics.com/pages/custom-colors" class="btn btn--secondary" target="_blank" rel="noopener">Sensaphonics colors →</a>
        <a href="https://microsonic-inc.com/colors/" class="btn btn--secondary" target="_blank" rel="noopener">Microsonic colors →</a>
      </div>
    </div>
  </section>

  <!-- ── Product Partners ───────────────────────────────────────── -->
  <section class="section section--alt">
    <div class="container">
      <h2>Product Partners</h2>
      <p class="mt-sm">We work with the best manufacturers in the industry.</p>
      <div class="partners mt-lg">
        <div class="partner-card"><img class="lg" src="/brand/partner-sensaphonics-trim.png" alt="Sensaphonics" /></div>
        <div class="partner-card"><img src="/brand/partner-ue.png" alt="Ultimate Ears Pro" /></div>
        <div class="partner-card"><img class="lg" src="/brand/partner-jhaudio.webp" alt="JH Audio — Jerry Harvey Audio" /></div>
        <div class="partner-card"><img src="/brand/partner-microsonic.png" alt="Microsonic" /></div>
      </div>
    </div>
  </section>

  <!-- ── CTA ────────────────────────────────────────────────────── -->
  <section class="section">
    <div class="container cta-section text-center">
      <h2>Ready to protect your hearing?</h2>
      <p class="mt-sm">Book a concierge appointment wherever works for you.</p>
      <div class="flex flex-wrap gap-sm mt-md" style="justify-content: center;">
        <a href={config.bookingConcierge} class="btn btn--primary" target="_blank" rel="noopener">Book a Concierge Visit</a>
        <a href={config.bookingClinic} class="btn btn--secondary" target="_blank" rel="noopener">Book a Friday Clinic</a>
      </div>
    </div>
  </section>
</Layout>

<style>
  /* ── Hero ── */
  .hero-grid { display: grid; grid-template-columns: 1.35fr 0.85fr; gap: 40px; align-items: center; }
  .hero-sub { font-size: 1.05rem; color: #444; }
  .hero-art img { width: 100%; max-width: 380px; margin-left: auto; }
  .schedule-note {
    margin-top: 20px; background: var(--off-white); border-left: 4px solid var(--sand);
    border-radius: 0 6px 6px 0; padding: 12px 18px; font-size: 0.92rem; color: var(--ink); max-width: 58ch;
  }

  /* ── PdB Package (teal) ── */
  .package {
    display: grid; grid-template-columns: 1.2fr 1fr; gap: 40px; align-items: center;
    background: var(--teal); color: #fff; border-radius: 16px; padding: 44px 48px;
  }
  .package h2 { color: #fff; }
  .eyebrow-sand { font-size: 0.8rem; font-weight: 600; letter-spacing: 0.1em; text-transform: uppercase; color: var(--sand); margin-bottom: 12px; }
  .package-desc { color: #eaf0f0; margin-top: 4px; }
  .package-price-row { display: flex; align-items: baseline; gap: 14px; flex-wrap: wrap; margin-top: 22px; }
  .package-price { font-size: 2.6rem; font-weight: 700; letter-spacing: -0.03em; color: #fff; line-height: 1; }
  .package-group { font-size: 0.85rem; color: var(--sand); }
  .package-includes { background: #fff; border-radius: 12px; padding: 28px; }
  .includes-label { font-size: 0.72rem; font-weight: 600; letter-spacing: 0.08em; text-transform: uppercase; color: var(--rust); margin-bottom: 16px; }
  .package-includes ul { list-style: none; display: flex; flex-direction: column; gap: 11px; }
  .package-includes li { font-size: 0.92rem; padding-left: 22px; position: relative; color: var(--ink); }
  .package-includes li::before { content: '✓'; position: absolute; left: 0; color: var(--teal); font-weight: 700; }

  /* ── À la Carte ── */
  .section-note { font-size: 0.9rem; color: var(--gray-mid); }
  .service-list { display: flex; flex-direction: column; }
  .service-row {
    display: grid; grid-template-columns: 1fr auto; gap: 24px; align-items: start;
    padding: 26px 0; border-bottom: 1px solid var(--gray-light);
  }
  .service-row:first-child { border-top: 1px solid var(--gray-light); }
  .service-info h3 { margin-bottom: 6px; font-size: 1.1rem; }
  .service-info p { font-size: 0.9rem; color: #555; max-width: 52ch; }
  .service-pricing { text-align: right; flex-shrink: 0; }
  .price { font-size: 1.35rem; font-weight: 700; letter-spacing: -0.01em; color: var(--teal); }
  .price-group-note { font-size: 0.78rem; color: var(--gray-mid); margin-top: 4px; white-space: nowrap; }

  /* ── Group block (copy left, table right) ── */
  .group-block {
    margin-top: 40px; padding-top: 32px; border-top: 1.5px solid var(--ink);
    display: grid; grid-template-columns: 1fr 1fr; gap: 40px; align-items: center;
  }
  .group-block h3 { font-size: 1.2rem; }
  .group-intro { font-size: 0.92rem; color: #555; }
  .group-intro a { font-weight: 600; color: var(--rust); white-space: nowrap; }
  .group-table { width: 100%; border-collapse: collapse; font-size: 0.92rem; }
  .group-table th, .group-table td { text-align: left; padding: 11px 16px; border-bottom: 1px solid var(--gray-light); }
  .group-table th {
    font-size: 0.7rem; font-weight: 600; letter-spacing: 0.06em; text-transform: uppercase;
    color: #fff; background: var(--teal);
  }
  .group-table th:first-child { border-top-left-radius: 8px; }
  .group-table th:last-child { border-top-right-radius: 8px; }
  .group-table td:first-child { font-weight: 500; }
  .group-table td:not(:first-child) { white-space: nowrap; color: var(--ink); }

  /* ── Custom Products ── */
  .products-intro { font-size: 1.05rem; color: #444; max-width: 62ch; }
  .product-grid { display: grid; grid-template-columns: repeat(2, 1fr); gap: 24px; }
  .product-card { background: var(--off-white); border: 1.5px solid var(--ink); border-radius: 12px; padding: 18px; box-shadow: 5px 5px 0 var(--teal); display: flex; flex-direction: column; }
  .product-photo { background: #fff; border-radius: 8px; height: 200px; display: flex; align-items: center; justify-content: center; margin-bottom: 18px; overflow: hidden; }
  .product-photo img { max-height: 176px; max-width: 90%; object-fit: contain; }
  .product-photo img.lg { max-height: 200px; max-width: 100%; }
  .product-card h3 { font-size: 1.15rem; margin-bottom: 8px; }
  .product-card p { font-size: 0.9rem; color: #555; }
  .product-note { margin-top: 10px; font-size: 0.82rem; font-weight: 600; color: var(--rust); }

  .color-sheets { display: flex; align-items: center; gap: 12px; flex-wrap: wrap; }
  .color-label { font-size: 0.9rem; font-weight: 600; color: var(--ink); }

  /* ── Partners ── */
  .partners { display: grid; grid-template-columns: repeat(4, 1fr); gap: 18px; }
  .partner-card {
    background: #fff; border: 1.5px solid var(--ink); border-radius: 10px; box-shadow: 4px 4px 0 var(--teal);
    height: 128px; display: flex; align-items: center; justify-content: center; padding: 16px;
  }
  .partner-card img { max-height: 60px; max-width: 82%; object-fit: contain; }
  .partner-card img.lg { max-height: 96px; max-width: 100%; }

  .cta-section { max-width: 560px; margin: 0 auto; }

  /* ── Buttons on teal ── */
  .btn--light { background: #fff; color: var(--teal); }
  .btn--onteal-ghost { background: transparent; color: #fff; border: 1.5px solid rgba(255,255,255,0.5); }

  @media (max-width: 768px) {
    .hero-grid { grid-template-columns: 1fr; }
    .hero-art { display: none; }
    .package { grid-template-columns: 1fr; padding: 32px 28px; }
    .service-row { grid-template-columns: 1fr; }
    .service-pricing { text-align: left; }
    .group-block { grid-template-columns: 1fr; gap: 24px; }
    .partners { grid-template-columns: repeat(2, 1fr); }
  }

  @media (max-width: 560px) {
    .product-grid { grid-template-columns: 1fr; }
    .partners { grid-template-columns: 1fr; }
  }
</style>
